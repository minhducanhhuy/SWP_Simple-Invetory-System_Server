generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =========================================================
// 1. QUẢN LÝ NGƯỜI DÙNG & PHÂN QUYỀN ĐA KHO (User & Auth)
// =========================================================

enum SystemRole {
  OWNER // Chủ doanh nghiệp (Full quyền)
  ADMIN // Quản trị viên hệ thống
  STAFF // Nhân viên bình thường (quyền hạn phụ thuộc vào Location)
}

enum LocationRole {
  MANAGER         // Quản lý kho
  WAREHOUSE_STAFF // Nhân viên kho (chỉ nhập xuất)
  SALESPERSON     // Nhân viên bán hàng (chỉ tạo đơn bán)
  STAFF           // Nhân viên chung
}

model User {
  id        String     @id @default(uuid())
  username  String     @unique
  password  String     // Hashed password
  fullName  String?
  email     String?    @unique
  phone     String?
  
  // Role cấp hệ thống
  systemRole SystemRole @default(STAFF)

  // User thuộc về những kho nào?
  locations UserLocation[]

  // Các phiếu đã tạo (Audit log)
  createdTickets  StockTicket[]
  createdPayments SupplierPayment[]

  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@map("users")
}

// Bảng lưu lời mời (sẽ xóa dòng này sau khi user đăng ký thành công)
model UserInvitation {
  id         String     @id @default(uuid())
  email      String     @unique // Một email chỉ được mời 1 lần tại 1 thời điểm
  token      String     @unique // Mã bí mật gửi qua mail
  systemRole SystemRole @default(STAFF) // Role dự kiến gán cho họ
  
  // (Optional) Nếu muốn mời thẳng vào làm quản lý kho nào đó thì thêm field này
  // locationId String? 
  
  expiresAt  DateTime   // Link này chỉ sống trong 24h hoặc 48h
  createdAt  DateTime   @default(now())

  @@map("user_invitations")
}

model Location {
  id        String   @id @default(uuid())
  code      String   @unique // Mã kho: KHO-HCM, KHO-HN
  name      String   // Tên kho: Kho Tổng, Cửa hàng 1
  address   String?
  
  // Nhân viên làm việc tại kho này
  users     UserLocation[]
  
  // Tồn kho tại kho này (Quan trọng)
  inventory InventoryItem[]

  // Các phiếu nhập/xuất liên quan đến kho này
  sourceTickets StockTicket[] @relation("SourceLocation")
  destTickets   StockTicket[] @relation("DestLocation")

  isActive  Boolean  @default(true)
  @@map("locations")
}

// Bảng trung gian: Phân quyền nhân viên theo từng kho
model UserLocation {
  id         String       @id @default(uuid())
  userId     String
  user       User         @relation(fields: [userId], references: [id])
  
  locationId String
  location   Location     @relation(fields: [locationId], references: [id])
  
  // Role cụ thể tại kho này
  role       LocationRole @default(STAFF)

  @@unique([userId, locationId]) // 1 user chỉ có 1 role tại 1 kho
  @@map("user_locations")
}

// =========================================================
// 2. QUẢN LÝ SẢN PHẨM & BIẾN THỂ (Product & Variant)
// =========================================================

model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  products    Product[]
  @@map("categories")
}

model Attribute {
  id      String            @id @default(uuid())
  name    String            @unique // VD: Color, Size
  options AttributeOption[]
  @@map("attributes")
}

model AttributeOption {
  id          String             @id @default(uuid())
  // 1. Giá trị hiển thị ra màn hình (User nhìn thấy cái này)
  value       String             // VD: "Red", "XL", "40", "128GB"
  
  // 2. Dùng để sắp xếp theo số học (Nếu là số thì điền, là chữ thì null)
  // VD: Size 40 -> 40.0; Size 39 -> 39.0
  numericValue Float?            
  
  // 3. Dùng để sắp xếp thủ công (Custom Sort)
  // VD: Size S=1, M=2, L=3, XL=4 (Giúp sort đúng thứ tự logic thay vì ABC)
  displayOrder Int               @default(0)

  // 4. Mã màu (nếu cần hiển thị ô màu)
  metaData    String?            // VD: #FF0000
  
  attributeId String
  attribute   Attribute          @relation(fields: [attributeId], references: [id])
  
  // Quan hệ ngược
  variantOptions VariantOption[]
  @@map("attribute_options")
}

// Sản phẩm cha (Thông tin chung)
model Product {
  id          String   @id @default(uuid())
  name        String
  description String?
  imageUrl    String?
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
  
  supplierId  String?  
  supplier    Supplier? @relation(fields: [supplierId], references: [id])

  variants    ProductVariant[]

  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@map("products")
}

// Biến thể (SKU cụ thể) - VD: Áo Thun Đỏ Size L
model ProductVariant {
  id          String   @id @default(uuid())
  sku         String   @unique // Mã SKU duy nhất
  name        String?  // Tên gợi nhớ: "Áo Thun - Đỏ - L"
  
  productId   String
  product     Product  @relation(fields: [productId], references: [id])

  // Giá cả (Decimal cho PostgreSQL)
  costPrice   Decimal  @default(0) @db.Decimal(15, 2)
  sellPrice   Decimal  @default(0) @db.Decimal(15, 2)

  // Cài đặt định mức tồn kho (Global warning)
  minStockLevel Int    @default(10)
  maxStockLevel Int?

  // Thuộc tính cấu thành (Màu, Size)
  options     VariantOption[]
  
  // Tồn kho chi tiết theo từng kho (Multi-warehouse inventory)
  inventory   InventoryItem[]
  
  // Lịch sử giao dịch
  transactions StockTransaction[]

  @@map("product_variants")
}

// Bảng nối: Variant này có những thuộc tính nào?
model VariantOption {
  id                String          @id @default(uuid())
  
  variantId         String
  variant           ProductVariant  @relation(fields: [variantId], references: [id])
  
  attributeOptionId String
  attributeOption   AttributeOption @relation(fields: [attributeOptionId], references: [id])

  @@unique([variantId, attributeOptionId])
  @@map("variant_options")
}

// =========================================================
// 3. QUẢN LÝ TỒN KHO ĐA ĐIỂM (Inventory Core)
// =========================================================

// Đây là bảng quan trọng nhất cho Multi-warehouse
// Trả lời câu hỏi: "Sản phẩm X ở Kho Y còn bao nhiêu cái?"
model InventoryItem {
  id               String         @id @default(uuid())
  
  locationId       String
  location         Location       @relation(fields: [locationId], references: [id])
  
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  
  quantity         Int            @default(0) // Số lượng thực tế tại kho này

  updatedAt        DateTime       @updatedAt
  
  @@unique([locationId, productVariantId]) // 1 kho chỉ có 1 dòng record cho 1 variant
  @@map("inventory_items")
}

// =========================================================
// 4. ĐỐI TÁC (Suppliers & Customers)
// =========================================================

model Supplier {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  phone       String?
  email       String?
  address     String?
  
  // Số dư đầu kỳ
  initialDebt Decimal  @default(0) @db.Decimal(15, 2)
  
  products    Product[]
  tickets     StockTicket[]     
  payments    SupplierPayment[] 

  @@map("suppliers")
}

model Customer {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  phone       String?  @unique
  address     String?
  
  tickets     StockTicket[] 

  @@map("customers")
}

// =========================================================
// 5. GIAO DỊCH KHO & PHIẾU (Operations)
// =========================================================

enum TicketType {
  IMPORT            // Nhập kho NCC
  SELL              // Xuất bán
  TRANSFER          // Chuyển kho
  ADJUSTMENT        // Kiểm kê/Cân bằng kho
  RETURN_TO_SUPP    // Trả hàng NCC
  RETURN_FROM_CUST  // Khách trả hàng
  SCRAP             // Hủy hàng
}

enum TicketStatus {
  DRAFT     // Nháp
  COMPLETED // Đã hoàn thành (Đã trừ kho)
  CANCELLED // Đã hủy
}

model Reason {
  id      String        @id @default(uuid())
  content String        @unique // VD: Hư hỏng, Hết hạn, Kiểm kê định kỳ
  type    TicketType    
  tickets StockTicket[]
  @@map("reasons")
}

// Phiếu kho (Header)
model StockTicket {
  id            String       @id @default(uuid())
  code          String       @unique // PN001, PX001...
  type          TicketType
  status        TicketStatus @default(COMPLETED)
  note          String?
  date          DateTime     @default(now())

  creatorId     String
  creator       User         @relation(fields: [creatorId], references: [id])
  
  // Đối tác liên quan
  supplierId    String?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  
  customerId    String?
  customer      Customer?    @relation(fields: [customerId], references: [id])

  reasonId      String?
  reason        Reason?      @relation(fields: [reasonId], references: [id])

  // Logic chuyển kho (Transfer): Từ kho nào sang kho nào?
  // Nếu Nhập/Bán thì chỉ cần quan tâm 1 trong 2 trường này
  sourceLocationId String?   
  sourceLocation   Location? @relation("SourceLocation", fields: [sourceLocationId], references: [id])

  destLocationId   String?   
  destLocation     Location? @relation("DestLocation", fields: [destLocationId], references: [id])

  // Tài chính
  totalAmount      Decimal   @default(0) @db.Decimal(15, 2)
  paidAmount       Decimal   @default(0) @db.Decimal(15, 2)
  paymentStatus    String?   // UNPAID, PARTIAL, PAID

  details       StockTransaction[]

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  @@map("stock_tickets")
}

// Chi tiết dòng hàng (Detail)
model StockTransaction {
  id               String         @id @default(uuid())
  
  ticketId         String
  ticket           StockTicket    @relation(fields: [ticketId], references: [id])
  
  productVariantId String
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  
  quantity         Int            // Số lượng biến động
  price            Decimal        @db.Decimal(15, 2) // Giá ghi nhận tại thời điểm đó
  
  @@map("stock_transactions")
}

// Thanh toán công nợ NCC
model SupplierPayment {
  id          String   @id @default(uuid())
  code        String   @unique // PC001
  
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  amount      Decimal  @db.Decimal(15, 2)
  date        DateTime @default(now())
  note        String?
  
  creatorId   String
  creator     User     @relation(fields: [creatorId], references: [id])

  @@map("supplier_payments")
}