generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Hoặc mysql tùy bạn
  url      = env("DATABASE_URL")
}

// =========================================================
// 1. QUẢN LÝ NGƯỜI DÙNG & PHÂN QUYỀN (Giữ nguyên)
// =========================================================
enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Notification {
  id        String           @id @default(uuid())
  title     String
  message   String
  type      NotificationType @default(INFO)
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
}

enum Role {
  OWNER // Chủ cửa hàng
  ADMIN_SYSTEM // Quản trị viên, chỉ quản lý cấu hình
  MANAGER // Quản lý
  WAREHOUSE_STAFF // Thủ kho
  SALESPERSON // Bán hàng
  STAFF // Nhân viên
}

model User {
  id       String  @id @default(uuid())
  username String  @unique
  password String
  fullName String?
  email    String? @unique
  address  String?
  phone    String?
  role     Role    @default(STAFF)

  resetToken          String?   @unique
  resetTokenExpiresAt DateTime?

  assignedLocations UserLocation[]

  createdTickets  StockTicket[]
  createdPayments SupplierPayment[]

  
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  
  Invoice         Invoice[]
  CashTransaction CashTransaction[]
  Notification Notification[]

  @@map("users")
}

model UserInvitation {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  role      Role     @default(STAFF)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("user_invitations")
}

model Location {
  id      String  @id @default(uuid())
  code    String  @unique
  name    String
  address String?

  assignedUsers UserLocation[]
  inventory     InventoryItem[]

  sourceTickets StockTicket[] @relation("SourceLocation")
  destTickets   StockTicket[] @relation("DestLocation")

  isActive        Boolean           @default(true)
  SupplierPayment SupplierPayment[]
  Invoice         Invoice[]
  CashTransaction CashTransaction[]

  @@map("locations")
}

model UserLocation {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  locationId String
  location   Location @relation(fields: [locationId], references: [id])
  assignedAt DateTime @default(now())

  @@unique([userId, locationId])
  @@map("user_locations")
}

// =========================================================
// 2. QUẢN LÝ SẢN PHẨM (Đã tối ưu cho Mini Mart)
// =========================================================

// Danh mục: Đồ uống, Đồ ăn nhanh, Hóa mỹ phẩm...
model Category {
  id          String    @id @default(uuid())
  name        String
  description String?
  products    Product[]

  @@map("categories")
}

// Đơn vị tính: Cái, Lon, Hộp, Thùng, Lốc... (US23)
model Unit {
  id       String    @id @default(uuid())
  name     String    @unique // Tên đơn vị
  products Product[]

  @@map("units")
}

// Sản phẩm 
model Product {
  id String @id @default(uuid())

  // 1. Định danh
  sku         String  @unique // Mã vạch (Barcode) in trên bao bì
  name        String // Tên SP: "Coca Cola 330ml"
  imageUrl    String?
  description String?

  // 2. Phân loại
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  // 3. Đơn vị tính (Quan trọng với Mini Mart)
  unitId String
  unit   Unit   @relation(fields: [unitId], references: [id])

  // 4. Giá cả
  costPrice Decimal @default(0) @db.Decimal(15, 2) // Giá nhập
  sellPrice Decimal @default(0) @db.Decimal(15, 2) // Giá bán lẻ

  // 5. Cài đặt kho
  minStockLevel Int  @default(10) // Cảnh báo khi dưới mức này
  maxStockLevel Int?

  // 6. Quan hệ
  inventory    InventoryItem[] // Tồn kho ở các chi nhánh
  transactions StockTransaction[] // Lịch sử nhập xuất

  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  supplierId    String? // <--- THÊM DÒNG NÀY
  supplier      Supplier?       @relation(fields: [supplierId], references: [id]) // <--- THÊM DÒNG NÀY
  InvoiceDetail InvoiceDetail[]

  @@map("products")
}

// =========================================================
// 3. QUẢN LÝ TỒN KHO 
// =========================================================

model InventoryItem {
  id String @id @default(uuid())

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  productId String // Đổi từ productVariantId -> productId
  product   Product @relation(fields: [productId], references: [id])

  quantity Int @default(0)

  updatedAt DateTime @updatedAt

  @@unique([locationId, productId])
  @@map("inventory_items")
}

// =========================================================
// 4. ĐỐI TÁC 
// =========================================================

model Supplier {
  id          String  @id @default(uuid())
  code        String  @unique
  name        String
  phone       String?
  email       String?
  address     String?
  initialDebt Decimal @default(0) @db.Decimal(15, 2)
  isActive    Boolean @default(true)

  tickets  StockTicket[]
  payments SupplierPayment[]
  products Product[] // <--- THÊM DÒNG NÀY

  @@map("suppliers")
}

model Customer {
  id      String  @id @default(uuid())
  code    String  @unique
  name    String
  phone   String? @unique
  address String?


  tickets         StockTicket[]
  Invoice         Invoice[]
  CashTransaction CashTransaction[]

  @@map("customers")
}

// =========================================================
// 5. GIAO DỊCH KHO 
// =========================================================

enum ReasonCode {
  BUY
  SELL
  SCRAP
  INTERNAL_USE
  GIFT
  TRANSFER
  ADJUSTMENT // Điều chỉnh
  RETURN_TO_SUPP
  RETURN_FROM_CUST
}

enum TicketType {
  IMPORT
  EXPORT
  STOCKTAKE // 
}

enum TicketStatus {
  DRAFT
  PENDING_APPROVAL // [THÊM MỚI] Chờ Manager duyệt (cho Kiểm kê & Yêu cầu chuyển kho)
  IN_TRANSIT // [THÊM MỚI] Đang luân chuyển (cho Chuyển kho)
  COMPLETED
  CANCELLED
}

model StockTicket {
  id     String       @id @default(uuid())
  code   String       @unique
  type   TicketType
  status TicketStatus @default(COMPLETED)
  note   String?
  date   DateTime     @default(now())

  reason ReasonCode?

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  supplierId String?
  supplier   Supplier? @relation(fields: [supplierId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  sourceLocationId String?
  sourceLocation   Location? @relation("SourceLocation", fields: [sourceLocationId], references: [id])

  destLocationId String?
  destLocation   Location? @relation("DestLocation", fields: [destLocationId], references: [id])

  details StockTransaction[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("stock_tickets")
}

model StockTransaction {
  id String @id @default(uuid())

  ticketId String
  ticket   StockTicket @relation(fields: [ticketId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity     Int
  originalCost Decimal @default(0) @db.Decimal(15, 2)
  price        Decimal @db.Decimal(15, 2)
  // --- [THÊM MỚI] CÁC CỘT PHỤC VỤ KIỂM KÊ & TRANSFER ---
  systemQty    Int? // Số lượng tồn trên máy lúc bắt đầu kiểm kê
  actualQty    Int? // Số lượng đếm thực tế (hoặc thực nhận khi chuyển kho)
  note         String?

  @@map("stock_transactions")
}

model SupplierPayment {
  id         String   @id @default(uuid())
  code       String   @unique
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id])
  amount     Decimal  @db.Decimal(15, 2)
  date       DateTime @default(now())
  note       String?
  creatorId  String
  creator    User     @relation(fields: [creatorId], references: [id])
  
  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  @@map("supplier_payments")
}

// =========================================================
// 6. QUẢN LÝ BÁN HÀNG (POS / HÓA ĐƠN)
// =========================================================

enum PaymentMethod {
  CASH // Tiền mặt
  BANK_TRANSFER // Chuyển khoản
  CARD // Quẹt thẻ
}

model Invoice {
  id   String @id @default(uuid())
  code String @unique // Mã hóa đơn (VD: HD-1698765432)

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  locationId String // Bán tại chi nhánh nào
  location   Location @relation(fields: [locationId], references: [id])

  totalAmount Decimal @db.Decimal(15, 2) // Tổng tiền hàng ban đầu
  discount    Decimal @default(0) @db.Decimal(15, 2) // Giảm giá (nếu có)
  finalAmount Decimal @db.Decimal(15, 2) // Tiền khách phải trả (Sau giảm giá)
  amountPaid  Decimal @db.Decimal(15, 2) // Tiền khách đưa

  paymentMethod PaymentMethod @default(CASH)
  note          String?

  createdAt DateTime @default(now())

  details         InvoiceDetail[]
  CashTransaction CashTransaction[]

  @@map("invoices")
}

model InvoiceDetail {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity  Int
  unitPrice Decimal @db.Decimal(15, 2) // Giá bán tại thời điểm xuất hóa đơn
  subTotal  Decimal @db.Decimal(15, 2) // Thành tiền (quantity * unitPrice)

  @@map("invoice_details")
}

// =========================================================
// 7. SỔ QUỸ (QUẢN LÝ DÒNG TIỀN THU / CHI NỘI BỘ & BÁN HÀNG)
// =========================================================

enum CashFlowType {
  IN // Thu vào (Bán hàng, thu nợ khách...)
  OUT // Chi ra (Điện, nước, lương, mặt bằng...)
}

enum CashFlowCategory {
  SALE // Thu tiền bán hàng (Tự động từ POS)
  DEBT_COLLECT // Thu nợ khách hàng
  EXPENSE // Chi phí vận hành (Điện, nước, lương...)
  OTHER_IN // Thu khác
  OTHER_OUT // Chi khác
}

model CashTransaction {
  id   String @id @default(uuid())
  code String @unique // Mã phiếu (VD: PT-123456)

  type     CashFlowType
  category CashFlowCategory

  amount        Decimal       @db.Decimal(15, 2)
  paymentMethod PaymentMethod @default(CASH)

  note String?

  locationId String
  location   Location @relation(fields: [locationId], references: [id])

  creatorId String
  creator   User   @relation(fields: [creatorId], references: [id])

  // Gắn với Khách hàng (Nếu có)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Gắn với Hóa đơn bán hàng để dễ dò lại
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("cash_transactions")
}
